  "bin": {
    "claude": "cli.js"
  },
  "main": "src/entrypoints/cli.tsx",
  "scripts": {
    "build": "bun build src/entrypoints/cli.tsx --outfile=cli.js --target=node --format=esm --define 'MACRO.VERSION=\"2.1.88\"' --define 'MACRO.PACKAGE_URL=\"@anthropic-ai/claude-code\"' --define 'MACRO.NATIVE_PACKAGE_URL=\"claude-code-native\"' --define 'MACRO.BUILD_TIME=\"2025-01-01T00:00:00Z\"' --define 'MACRO.VERSION_CHANGELOG=\"\"' --define 'MACRO.ISSUES_EXPLAINER=\"\"' --define 'MACRO.FEEDBACK_CHANNEL=\"\"'",
    "build:sourcemap": "bun build src/entrypoints/cli.tsx --outdir=dist --entry-naming=cli.js --target=node --format=esm --sourcemap=external --define 'MACRO.VERSION=\"2.1.88\"' --define 'MACRO.PACKAGE_URL=\"@anthropic-ai/claude-code\"' --define 'MACRO.NATIVE_PACKAGE_URL=\"claude-code-native\"' --define 'MACRO.BUILD_TIME=\"2025-01-01T00:00:00Z\"' --define 'MACRO.VERSION_CHANGELOG=\"\"' --define 'MACRO.ISSUES_EXPLAINER=\"\"' --define 'MACRO.FEEDBACK_CHANNEL=\"\"'",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "bun run src/entrypoints/dev.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
